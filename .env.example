# Copy file này thành .env và điền giá trị thật

# Gemini API key (lấy free tại https://aistudio.google.com/apikey)
# Nếu bỏ trống → tự fallback sang rule-based NLU
GEMINI_API_KEY=

# Whisper ASR
WHISPER_MODEL=small        # tiny / base / small / medium / large-v3
WHISPER_DEVICE=cpu         # cpu / cuda
WHISPER_COMPUTE=int8       # int8 cho CPU, float16 hoặc float32 cho GPU

# Speaker checkpoint (từ Tuần 1)
# Nếu file không tồn tại → tự fallback sang pretrained SpeechBrain
SPEAKER_CKPT=./checkpoints/best_model.pt

# =============================================================
# Google OAuth 2.0 — Gmail API (thay thế SMTP App Password)
# =============================================================
# 1. Vào https://console.cloud.google.com → tạo project mới
# 2. APIs & Services → Enable "Gmail API"
# 3. OAuth consent screen → External → điền tên app → Add scope:
#      https://www.googleapis.com/auth/gmail.send
# 4. Credentials → Create OAuth client ID → Web application
#    Authorized redirect URI: http://localhost:5000/auth/google/callback
# 5. Tải JSON → lấy client_id và client_secret dán vào đây
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Phải khớp chính xác với URI trong Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Admin panel
ADMIN_PASS=
