# Copy file này thành .env và điền giá trị thật

# Gemini API key (lấy free tại https://aistudio.google.com/apikey)
# Nếu bỏ trống → tự fallback sang rule-based NLU
GEMINI_API_KEY=

# Whisper ASR
WHISPER_MODEL=small        # tiny / base / small / medium / large-v3
WHISPER_DEVICE=cpu         # cpu / cuda
WHISPER_COMPUTE=int8       # int8 cho CPU, float16 hoặc float32 cho GPU

# Speaker checkpoint (từ Tuần 1)
# Nếu file không tồn tại → tự fallback sang pretrained SpeechBrain
SPEAKER_CKPT=./checkpoints/best_model.pt
